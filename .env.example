# ============================================
# DATABASE CONFIGURATION
# ============================================
# Docker Compose собирает DATABASE_URL/DIRECT_URL из этих значений.
# Для production измените POSTGRES_PASSWORD. Используйте URL-safe пароль, например: openssl rand -hex 24
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=wa_manager

# Эти URL нужны для локальных prisma/npm команд без Docker Compose.
DATABASE_URL="postgresql://postgres:change_this_password@postgres:5432/wa_manager?schema=public"
DIRECT_URL="postgresql://postgres:change_this_password@postgres:5432/wa_manager?schema=public"

# ============================================
# NEXT.JS CONFIGURATION
# ============================================
# Замените на ваш домен или IP адрес сервера
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com

# ============================================
# API CONFIGURATION
# ============================================
API_PORT=5001

# ============================================
# SECURITY
# ============================================
# ВАЖНО: Сгенерируйте случайный ключ для production!
# Можно использовать: openssl rand -base64 32
API_SECRET_KEY=your-super-secret-key-change-this-in-production

# ============================================
# REDIS CONFIGURATION (для BullMQ)
# ============================================
# Для Docker Compose используйте имя сервиса "redis"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production
